# =============================================================================
# Wildon API — Environment Variables
# =============================================================================
# Copy to .env and fill in the REPLACE_ME placeholders.
# =============================================================================

# ---------------------------------------------------------------------------
# App/runtime
# ---------------------------------------------------------------------------
APP_NAME=wildon
RUST_LOG=info
JWT_ISSUER=https://auth.wildon.local
JWT_EXPECTED_ISSUER=https://auth.wildon.local
JWT_TTL_SECONDS=3600
AUTH_DB_MAX_CONNECTIONS=20
AUTH_SESSION_CACHE_TTL_SECONDS=600
AUTH_CLEANUP_INTERVAL_SECONDS=3600
AUTH_ACCESS_TTL_PUBLIC_SECONDS=900
AUTH_ACCESS_TTL_PLATFORM_SECONDS=600
AUTH_ACCESS_TTL_CONTROL_SECONDS=300
AUTH_REFRESH_TTL_PUBLIC_SECONDS=2592000
AUTH_REFRESH_TTL_PLATFORM_SECONDS=1209600
AUTH_REFRESH_TTL_CONTROL_SECONDS=1209600
AUTH_ABSOLUTE_SESSION_TTL_PUBLIC_SECONDS=7776000
AUTH_ABSOLUTE_SESSION_TTL_PLATFORM_SECONDS=2592000
AUTH_ABSOLUTE_SESSION_TTL_CONTROL_SECONDS=2592000
AUTH_INACTIVITY_TTL_PUBLIC_SECONDS=2592000
AUTH_INACTIVITY_TTL_PLATFORM_SECONDS=1209600
AUTH_INACTIVITY_TTL_CONTROL_SECONDS=604800
AUTH_MFA_TOTP_ISSUER=Wildon
AUTH_MFA_TOTP_DRIFT_STEPS=1
AUTH_MFA_LOGIN_CHALLENGE_TTL_SECONDS=300
AUTH_MFA_BACKUP_CODES_COUNT=10

# ---------------------------------------------------------------------------
# Bind/listen addresses
# ---------------------------------------------------------------------------
GATEWAY_BIND_ADDR=127.0.0.1:8080
AUTH_HTTP_BIND_ADDR=127.0.0.1:8081
PLATFORM_HTTP_BIND_ADDR=127.0.0.1:8083
CONTROL_HTTP_BIND_ADDR=127.0.0.1:8084
CONTROL_ALLOWED_HOSTS=control-api.wildon.internal,control.wildon.local,localhost,127.0.0.1
AUTH_GRPC_BIND_ADDR=127.0.0.1:50051
PUBLIC_GRPC_BIND_ADDR=127.0.0.1:50052
CORE_GRPC_BIND_ADDR=127.0.0.1:50053
LOGS_GRPC_BIND_ADDR=127.0.0.1:50054
STORAGE_GRPC_BIND_ADDR=127.0.0.1:50055
EXPORT_GRPC_BIND_ADDR=127.0.0.1:50056
USERS_GRPC_BIND_ADDR=127.0.0.1:50057
API_CLIENTS_GRPC_BIND_ADDR=127.0.0.1:50058
BILLING_GRPC_BIND_ADDR=127.0.0.1:50059

# ---------------------------------------------------------------------------
# Internal gRPC endpoints used by gateway
# ---------------------------------------------------------------------------
AUTH_GRPC_ENDPOINT=http://127.0.0.1:50051
PUBLIC_GRPC_ENDPOINT=http://127.0.0.1:50052
CORE_GRPC_ENDPOINT=http://127.0.0.1:50053
LOGS_GRPC_ENDPOINT=http://127.0.0.1:50054
STORAGE_GRPC_ENDPOINT=http://127.0.0.1:50055
EXPORT_GRPC_ENDPOINT=http://127.0.0.1:50056
USERS_GRPC_ENDPOINT=http://127.0.0.1:50057
API_CLIENTS_GRPC_ENDPOINT=http://127.0.0.1:50058
BILLING_GRPC_ENDPOINT=http://127.0.0.1:50059

# ---------------------------------------------------------------------------
# Service ports
# ---------------------------------------------------------------------------
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
PUBLIC_SERVICE_PORT=8082
PLATFORM_SERVICE_PORT=8083
CONTROL_SERVICE_PORT=8084
CORE_SERVICE_PORT=8085
STORAGE_SERVICE_PORT=8086
EXPORT_SERVICE_PORT=8087
LOGS_SERVICE_PORT=8088

# ---------------------------------------------------------------------------
# Docker compose host port mappings
# ---------------------------------------------------------------------------
YUGABYTE_YSQL_HOST_PORT=5433
YUGABYTE_MASTER_UI_HOST_PORT=7000
YUGABYTE_TSERVER_UI_HOST_PORT=9000
REDIS_HOST_PORT=6379
NATS_HOST_PORT=4222
NATS_MONITOR_HOST_PORT=8222

# ---------------------------------------------------------------------------
# YugabyteDB YSQL (local compose)
# ---------------------------------------------------------------------------
DATABASE_HOST=127.0.0.1
DATABASE_PORT=${YUGABYTE_YSQL_HOST_PORT}
DATABASE_USER=yugabyte
DATABASE_PASSWORD=
DATABASE_NAME=wildon
DATABASE_URL=postgresql://yugabyte@127.0.0.1:${YUGABYTE_YSQL_HOST_PORT}/wildon

# ---------------------------------------------------------------------------
# Redis (local compose)
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:${REDIS_HOST_PORT}

# ---------------------------------------------------------------------------
# NATS (local compose)
# ---------------------------------------------------------------------------
NATS_URL=nats://127.0.0.1:${NATS_HOST_PORT}

# ---------------------------------------------------------------------------
# Internal access over WireGuard (ops/monitoring)
# ---------------------------------------------------------------------------
INTERNAL_GRAFANA_URL=http://grafana.wildon.internal
INTERNAL_ARGOCD_URL=http://argocd.wildon.internal
K3S_API_URL=https://10.10.0.1:6443
K3S_NAMESPACE=wildon
K3S_CLUSTER_NAME=wildon-k3s
K3S_OBSERVER_CONTEXT=wildon-observer
K3S_DEPLOYER_CONTEXT=wildon-deployer

# ---------------------------------------------------------------------------
# Gateway rate limiting and browser security
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=1
CLIENT_POLICY_CACHE_TTL_SECONDS=60
GATEWAY_MAX_REQUEST_BODY_BYTES=32768
BROWSER_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---------------------------------------------------------------------------
# Internal gRPC reliability/backpressure defaults
# ---------------------------------------------------------------------------
GRPC_CONNECT_TIMEOUT_MS=500
GRPC_REQUEST_TIMEOUT_MS=15000
GRPC_CONCURRENCY_LIMIT=128
GRPC_KEEPALIVE_SECS=30
GRPC_BREAKER_FAILURE_THRESHOLD=5
GRPC_BREAKER_OPEN_SECS=15
GRPC_BREAKER_HALF_OPEN_MAX_CALLS=1

# ---------------------------------------------------------------------------
# Internal gRPC mTLS/authn/authz
# ---------------------------------------------------------------------------
INTERNAL_TLS_ENABLE_CLIENT=0
INTERNAL_TLS_REQUIRE_SERVER_TLS=0
INTERNAL_TLS_REQUIRE_CLIENT_AUTH=0
INTERNAL_TLS_CA_CERT_PATH=
INTERNAL_TLS_SERVER_CERT_PATH=
INTERNAL_TLS_SERVER_KEY_PATH=
INTERNAL_TLS_CLIENT_CERT_PATH=
INTERNAL_TLS_CLIENT_KEY_PATH=
INTERNAL_AUTH_REQUIRE_MTLS=0
INTERNAL_AUTH_SPIFFE_PREFIX=spiffe://wildon.internal/service/
INTERNAL_CALLER_SERVICE=

# ---------------------------------------------------------------------------
# Core-service entitlement cache
# ---------------------------------------------------------------------------
CORE_ENTITLEMENT_CACHE_TTL_SECONDS=30

# ---------------------------------------------------------------------------
# S3-compatible storage (Wasabi)
# ---------------------------------------------------------------------------
S3_ENDPOINT=https://s3.wasabisys.com
S3_REGION=us-east-1
S3_BUCKET=wildon-dev
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
CONTROL_INTERNAL_WEB_TOKEN=REPLACE_ME

# ---------------------------------------------------------------------------
# Email (SendGrid)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=REPLACE_ME
SENDGRID_EMAIL_FROM=noreply@wildon.com.au

# ---------------------------------------------------------------------------
# SMS (Twilio)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Push Notifications (Firebase)
# ---------------------------------------------------------------------------
FCM_SERVICE_ACCOUNT_JSON=

# ---------------------------------------------------------------------------
# Social Login
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_ALLOWED_AUDIENCES=
APPLE_OAUTH_ALLOWED_AUDIENCES=
SOCIAL_LOGIN_NONCE_REQUIRED=true

# ---------------------------------------------------------------------------
# Stripe — Test
# ---------------------------------------------------------------------------
STRIPE_TEST_KEY=REPLACE_ME
STRIPE_TEST_SECRET_KEY=REPLACE_ME
STRIPE_TEST_WEBHOOK_SECRET=REPLACE_ME
STRIPE_TEST_WEBHOOK_TOLERANCE_SECONDS=300

# ---------------------------------------------------------------------------
# Stripe — Live
# ---------------------------------------------------------------------------
STRIPE_LIVE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_LIVE_WEBHOOK_TOLERANCE_SECONDS=300

# ---------------------------------------------------------------------------
# AI (optional)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Billing idempotency controls
# ---------------------------------------------------------------------------
BILLING_IDEMPOTENCY_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Provider failover toggles (local testing)
# ---------------------------------------------------------------------------
SENDGRID_FORCE_FAIL=0
TWILIO_FORCE_FAIL=0
FCM_FORCE_FAIL=0

# ---------------------------------------------------------------------------
# Default Test Accounts (seeded by migrations — not read at runtime)
# ---------------------------------------------------------------------------
# These are baked into the database via SQL migrations. Listed here as a
# reference so you know which credentials work after a fresh migration.
#
#   Surface      | Email                     | Password        | Role
#   -------------|---------------------------|-----------------|------------
#   Control      | control@wildon.com.au    | G1Control!2026  | superadmin
#   Support      | support@wildon.com.au    | G1Control!2026  | support
#   My           | my@wildon.com.au         | G1Control!2026  | user
#   Platform     | platform@wildon.com.au   | G1Platform!2026 | partner
#   Public       | testuser@wildon.com.au   | G1User!2026     | user
#   Owner        | zubair@wildon.com.au     | Planet.23       | superadmin
#
# Rotate or remove these before going live.
